{
  "stack": {
    "framework": "astro",
    "css": "tailwind",
    "package_manager": "pnpm",
    "host": "netlify"
  },
  "tracking": {
    "microsoft_clarity_id": "",
    "ga4_id": "",
    "search_console_verification": "",
    "bing_verification": ""
  },
  "schema": {
    "organization_required": true,
    "faq_required_on_every_page": true,
    "local_business": false
  },
  "content_rules": {
    "section_min_words": 120,
    "section_max_words": 180,
    "faq_answer_words": 40,
    "meta_title_max_chars": 60,
    "meta_description_chars": [150, 160]
  },
  "ai_crawlers_allow_all": true,
  "ivy_outbound_governance": true
}
