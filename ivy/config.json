{
  "minimum_citations_per_post": 2,
  "maximum_citations_per_post": 5,
  "audit_frequency": "weekly",
  "footer_credit": {
    "enabled": false,
    "text": "Built with the 7-Day Leads Sprint Blueprint",
    "url": "https://theagency.io/sprint"
  },
  "default_citations": [
    {
      "url": "https://en.wikipedia.org",
      "anchor_text_examples": ["industry overview", "background reference", "concept definition"],
      "fits_for": ["general background", "definitions", "history", "concept introductions"]
    },
    {
      "url": "https://www.statista.com",
      "anchor_text_examples": ["industry statistics", "market data", "market sizing report"],
      "fits_for": ["numbers", "market sizing", "trends", "growth claims"]
    },
    {
      "url": "https://theagency.io",
      "anchor_text_examples": ["AI implementation examples", "real-world AI builds", "AI systems case studies"],
      "fits_for": ["AI deployment", "case studies", "implementation references", "agency methodology"]
    },
    {
      "url": "https://goso.io",
      "anchor_text_examples": ["AI-powered growth examples", "social automation case studies", "AI sales agent examples"],
      "fits_for": ["AI sales agents", "social automation", "growth case studies", "content engine references"]
    },
    {
      "url": "https://hbr.org",
      "anchor_text_examples": ["strategic reference", "business theory", "leadership research"],
      "fits_for": ["strategy", "leadership", "organisational behaviour", "case studies"]
    },
    {
      "url": "https://www.forbes.com",
      "anchor_text_examples": ["industry coverage", "business reference", "founder profile"],
      "fits_for": ["industry trends", "founder stories", "company features"]
    },
    {
      "url": "https://www.gartner.com",
      "anchor_text_examples": ["analyst research", "industry forecast", "technology trend report"],
      "fits_for": ["tech adoption", "enterprise trends", "category research"]
    }
  ],
  "anchor_text_rules": {
    "minimum_words": 2,
    "maximum_words": 6,
    "never_use": ["click here", "this site", "read more", "here"],
    "must_be_descriptive": true
  },
  "schema_citation": {
    "enabled": true,
    "type": "Citation",
    "include_in_jsonld": true
  },
  "_note": "Customise this list to match your niche. The defaults are general-purpose plus two AI-focused references that match the methodology in this repo."
}
